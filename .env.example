# Copy to .env for local dev. In production these are set in Coolify → Environment.

# nuxt-auth-utils session encryption key — 32+ random chars. REQUIRED.
#   generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Guards /api/admin/* (publish + client management). Admin API is disabled (503)
# until this is set. REQUIRED for the publish/add-client CLIs against a live site.
#   generate: openssl rand -hex 32
NUXT_ADMIN_TOKEN=

# Absolute path to the persistent volume holding client reports + clients.json.
# Local dev can leave this blank (defaults to ./.data). In prod: /data
NUXT_CLIENT_DATA_DIR=

# --- Used by the CLIs (scripts/publish.mjs, scripts/add-client.mjs) ---
# Where to push reports/clients when NOT using --local:
PRINCIPLES_ADMIN_URL=https://principles.studio
PRINCIPLES_ADMIN_TOKEN=
